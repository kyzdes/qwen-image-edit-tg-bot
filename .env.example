# Токен бота из @BotFather (обязательно)
BOT_TOKEN=

# ID пользователей, которым разрешён доступ, через запятую или пробел.
# Пусто => бот открыт для всех (в логах будет предупреждение).
ALLOWED_USER_IDS=

# ID Hugging Face Space с моделью (можно не менять)
SPACE_ID=productowner/Qwen-Image-Edit-2509-LoRAs-Fast-v2

# Токен Hugging Face (необязательно, для публичного Space не нужен)
HF_TOKEN=

# Таймаут запроса к Space в секундах (по умолчанию 300)
REQUEST_TIMEOUT=300
